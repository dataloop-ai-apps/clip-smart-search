{
  "name": "clip-image-search",
  "displayName": "Semantic (CLIP)",
  "description": "CLIP Image search using NLP",
  "version": "0.1.24",
  "scope": "public",
  "attributes": {
    "Category": "Model",
    "Provider": "Open AI",
    "License": "MIT",
    "NLP": "Embeddings",
    "Media Type": [
      "Image",
      "Text"
    ]
  },
  "codebase": {
    "type": "git",
    "gitUrl": "https://github.com/dataloop-ai-apps/clip-smart-search",
    "gitTag": "0.1.24"
  },
  "components": {
    "computeConfigs": [
      {
        "name": "clip-deploy",
        "runtime": {
          "podType": "regular-m",
          "concurrency": 1,
          "runnerImage": "gcr.io/viewo-g/piper/agent/runner/apps/clip-smart-search:0.1.1",
          "autoscaler": {
            "type": "rabbitmq",
            "minReplicas": 0,
            "maxReplicas": 2,
            "queueLength": 100
          }
        }
      },
      {
        "name": "clip-train",
        "runtime": {
          "podType": "gpu-t4",
          "concurrency": 1,
          "runnerImage": "gcr.io/viewo-g/piper/agent/runner/apps/clip-smart-search:0.1.1",
          "autoscaler": {
            "type": "rabbitmq",
            "minReplicas": 0,
            "maxReplicas": 2,
            "queueLength": 100
          }
        },
        "executionTimeout": 36000000
      }
    ],
    "modules": [
      {
        "name": "clip-module",
        "entryPoint": "model_adapter.py",
        "className": "ClipAdapter",
        "description": "CLIP model adapter for search with NLP",
        "functions": [
          {
            "name": "train_model",
            "computeConfig": "clip-train",
            "input": [
              {
                "type": "Model",
                "name": "model",
                "description": "Dataloop Model Entity"
              }
            ],
            "output": [
              {
                "type": "Model",
                "name": "model",
                "description": "Dataloop Model Entity"
              }
            ],
            "displayName": "Train A Model",
            "displayIcon": "icon-dl-models-management",
            "description": "Function to train CLIP model"
          },
          {
            "name": "embed_items",
            "input": [
              {
                "type": "Item[]",
                "name": "items",
                "description": "The input items for embeddings."
              }
            ],
            "output": [
              {
                "type": "Item[]",
                "name": "items",
                "description": "The same input items for embeddings."
              },
              {
                "type": "Json",
                "name": "json",
                "description": "Embeddings of items."
              }
            ],
            "displayName": "Embed Items",
            "displayIcon": "icon-dl-embeddings",
            "description": "Extract features function of the model for a list of items."
          },
          {
            "name": "embed_dataset",
            "input": [
              {
                "type": "Dataset",
                "name": "dataset",
                "description": "The input dataset of the items required for prediction."
              },
              {
                "type": "Json",
                "name": "filters",
                "description": "The DQL in json format to get all the items required for prediction."
              }
            ],
            "output": [],
            "displayName": "Embed Dataset",
            "displayIcon": "icon-dl-embeddings",
            "description": "Extract features function of the model for a dataset."
          }
        ]
      }
    ],
    "models": [
      {
        "name": "clip-smart-search",
        "moduleName": "extract-features",
        "scope": "project",
        "status": "pre-trained",
        "inputType": "text",
        "configuration": {
          "model_name": "ViT-B/32",
          "embeddings_size": 512
        },
        "description": "OpenAI CLIP model for search with NLP"
      }
    ],
    "panels": [
      {
        "name": "clip-smart-search",
        "supportedSlots": [
          {
            "type": "datasetBrowserSearch",
            "configuration": {
              "layout": {
                "schema": {
                  "fields": [
                    {
                      "name": "Text Box",
                      "title": "",
                      "props": {
                        "title": false,
                        "type": "string",
                        "placeholder": "Natural language based search, e.g. image with high brightness or images with red cars"
                      },
                      "widget": "dl-input"
                    }
                  ]
                }
              },
              "invoke": {
                "type": "script",
                "namespace": "run",
                "source": "https://raw.githubusercontent.com/dataloop-ai-apps/clip-smart-search/main/entire.js"
              }
            }
          }
        ]
      }
    ],
    "toolbars": [
      {
        "displayName": "Semantic (CLIP)",
        "icon": "icon-dl-models-management",
        "location": "datasetBrowserSearchOption",
        "invoke": {
          "type": "panel",
          "namespace": "clip-inference.extract-features.embed_items"
        }
      },
      {
        "displayName": "Clip Extract Features",
        "invoke": {
          "type": "function",
          "namespace": "clip-inference.clip-extraction.embed_items"
        },
        "location": "datasetBrowserApps",
        "icon": "icon-dl-edit"
      }
    ],
    "services": [
      {
        "name": "clip-inference",
        "moduleName": "extract-features",
        "packageRevision": "latest",
        "runtime": {
          "podType": "regular-m",
          "concurrency": 10,
          "runnerImage": "gcr.io/viewo-g/piper/agent/runner/cpu/clip-search:0.1.0",
          "autoscaler": {
            "type": "rabbitmq",
            "minReplicas": 0,
            "maxReplicas": 2,
            "queueLength": 100
          }
        },
        "executionTimeout": 360000
      }
    ]
  }
}